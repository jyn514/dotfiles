root = true
[*]
	indent_style = space
	indent_size = 2
[*.{clj,cljc,edn,js,ts,mts,scss,html,md,yaml,yml,xml}]
	indent_style = space
	# indent_size = 2
[*.{py,rs,toml}]
	indent_style = space
	indent_size = 4
# c gets confused for cpp all the time 🥲
[*.{c,cpp,csh}]
	indent_size = 8
[*.ninja]
	indent_style = space
[*.md]
	max_line_length = off
[*.{lua,editorconfig,mk}]
	indent_style = tab
[Makefile]
	indent_style = tab
